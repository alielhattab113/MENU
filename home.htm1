<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Noodlezoo</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{
background:#000;
display:flex;
justify-content:center;
align-items:center;
min-height:100vh;
padding:20px;
}

.container{
width:100%;
max-width:420px;
}

.logo{
text-align:center;
margin-bottom:35px;
}

.logo img{
width:150px;
}

.card{
display:flex;
align-items:center;
gap:20px;
background:#111;
border:2px solid #ff8a00;
border-radius:22px;
padding:20px;
margin-bottom:20px;
text-decoration:none;
transition:.3s;
box-shadow:0 0 20px rgba(255,138,0,.15);
}

.card:hover{
transform:translateY(-5px);
box-shadow:0 0 30px rgba(255,138,0,.35);
}

.icon{
font-size:48px;
width:60px;
text-align:center;
}

.menu{
color:#ff9800;
}

.whatsapp{
color:#25D366;
}

.instagram{
background:linear-gradient(45deg,#833AB4,#E1306C,#FCAF45);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
}

.text h2{
color:#fff;
font-size:24px;
margin-bottom:5px;
}

.text p{
color:#ff9800;
font-size:15px;
}

.footer{
margin-top:25px;
text-align:center;
color:#777;
font-size:13px;
}

</style>

</head>

<body>

<div class="container">

<div class="logo">
<img src="logo.png" alt="Noodlezoo">
</div>

<a href="MENU%20NOODLEZOO.pdf" target="_blank" class="card">

<div class="icon menu">
<i class="fa-solid fa-bowl-food"></i>
</div>

<div class="text">
<h2>Online Menu</h2>
<p>Tap to view</p>
</div>

</a>

<a href="https://wa.me/971561065002" target="_blank" class="card">

<div class="icon whatsapp">
<i class="fa-brands fa-whatsapp"></i>
</div>

<div class="text">
<h2>WhatsApp</h2>
<p>Chat with us</p>
</div>

</a>

<a href="https://instagram.com/noodlezoo_" target="_blank" class="card">

<div class="icon instagram">
<i class="fa-brands fa-instagram"></i>
</div>

<div class="text">
<h2>Instagram</h2>
<p>Follow us</p>
</div>

</a>

<div class="footer">
©️ 2026 Noodlezoo
</div>

</div>

</body>
</html>
