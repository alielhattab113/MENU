<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Noodlezoo</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#000;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

.container{
width:90%;
max-width:420px;
}

.card{
display:flex;
align-items:center;
gap:20px;
background:#111;
border:2px solid #ff8c00;
border-radius:20px;
padding:20px;
margin-bottom:20px;
text-decoration:none;
transition:.3s;
}

.card:hover{
transform:scale(1.03);
}

.icon{
font-size:48px;
width:60px;
text-align:center;
}

.menu{color:#ff9800;}
.whatsapp{color:#25D366;}
.instagram{
background:linear-gradient(45deg,#833AB4,#FD1D1D,#FCAF45);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
}

.text h2{
color:#fff;
font-size:26px;
}

.text p{
color:#ff9800;
}

</style>

</head>

<body>

<div class="container">

<a class="card" href="MENU%20NOODLEZOO.pdf" target="_blank">

<div class="icon menu">
<i class="fa-solid fa-bowl-food"></i>
</div>

<div class="text">
<h2>Online Menu</h2>
<p>Tap to view</p>
</div>

</a>

<a class="card" href="https://wa.me/971561065002">

<div class="icon whatsapp">
<i class="fa-brands fa-whatsapp"></i>
</div>

<div class="text">
<h2>WhatsApp</h2>
<p>Chat with us</p>
</div>

</a>

<a class="card" href="https://instagram.com/noodlezoo_">

<div class="icon instagram">
<i class="fa-brands fa-instagram"></i>
</div>

<div class="text">
<h2>Instagram</h2>
<p>Follow us</p>
</div>

</a>

</div>

</body>
</html>
